{
  "manifest_version": 3,
  "name": "DorkForge Harvester",
  "version": "0.1.0",
  "description": "Extract URLs from Google/Bing/DDG search results into SQLiDumper-ready feeds using your real browser session.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "downloads"
  ],
  "host_permissions": [
    "https://*.google.com/*",
    "https://www.bing.com/*",
    "https://duckduckgo.com/*",
    "https://html.duckduckgo.com/*",
    "https://search.yahoo.com/*",
    "https://www.startpage.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/search*",
        "https://www.google.tn/search*",
        "https://www.bing.com/search*",
        "https://duckduckgo.com/*",
        "https://html.duckduckgo.com/html/*",
        "https://search.yahoo.com/search*",
        "https://www.startpage.com/do/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "DorkForge Harvester"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["popup/popup.html"],
      "matches": ["<all_urls>"]
    }
  ]
}